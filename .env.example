# ============================================
# Starmory App - Environment Configuration
# ============================================
# ⚠️ หมายเหตุ
# - แต่ละคนต้องสร้างไฟล์ .env ของตัวเอง
# - ห้าม commit ไฟล์ .env ที่มีค่าจริงขึ้น git!
# ✅ ไฟล์ .env ถูกใส่ใน .gitignore แล้ว (ปลอดภัย)
# ============================================

# Gemini API Key
# Get your key from: https://ai.google.dev/
# Each developer must generate their own key!

GEMINI_API_KEY=your_gemini_api_key_here


# Supabase Configuration
# คัดลอกค่าจาก Supabase Project Settings → API
# 1. ไปที่ https://supabase.com
# 2. เลือก project ของคุณ
# 3. ไปที่ Settings → API
# 4. คัดลอก Project URL และ anon/public key

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here


# Google OAuth Configuration (Optional - ถ้าต้องการใช้ Google Sign-In)
# คัดลอกจาก Google Cloud Console
# 1. ไปที่ https://console.cloud.google.com
# 2. APIs & Services → Credentials
# 3. สร้าง OAuth 2.0 Client ID สำหรับ Web application
# 4. คัดลอก Client ID และ Client Secret

GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here


# Environment
ENV=dev